@using EventEase.Models

<div class="card shadow-sm mb-3" style="width: 18rem; padding: 15px; border: 1px solid #ccc;">
    
    <EditForm Model="Event">
        <DataAnnotationsValidator />
        
        <label>Edit Event Name:</label>
        <InputText @bind-Value="Event.Name" class="form-control mb-1" />
        
        <ValidationMessage For="@(() => Event.Name)" style="color: red; font-size: 0.85em;" />
    </EditForm>
    
    <h3 class="mt-2">@Event.Name</h3>
    
    <p>
        <strong>Date:</strong> @Event.Date.ToString("MMM dd, yyyy")<br />
        <strong>Location:</strong> @Event.Location
    </p>
    
    <a href="/event/@Event.Id">View Details</a>
    
</div>

@code {
    [Parameter]
    public EventModels Event { get; set; } = new();
}