@using EventEase.Models

<div class="card p-3 shadow-sm">
	<div class="card-body">
		<h3 class="card-title mb-3">Event Details</h3>

		@if (Event is null)
		{
			<p class="text-muted mb-0">No event data available.</p>
		}
		else
		{
			<div class="mb-3">
				<label class="form-label" for="event-name">Event Name</label>
				<input id="event-name" class="form-control" @bind="Event.Name" />
			</div>

			<p class="mb-1"><strong>ID:</strong> @Event.Id</p>
			<p class="mb-1"><strong>Date:</strong> @Event.Date.ToString("yyyy-MM-dd")</p>
			<p class="mb-0"><strong>Location:</strong> @Event.Location</p>
		}
	</div>
</div>

@code {
	[Parameter]
	public EventModels? Event { get; set; }
}
